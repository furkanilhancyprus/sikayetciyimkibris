APP_NAME="Şikayetçiyim Kıbrıs"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sikayetciyimkibris.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=90
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.sikayetciyimkibris.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=private

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="bildirim@sikayetciyimkibris.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

ADMIN_NAME="Şikayetçiyim Kıbrıs Admin"
ADMIN_EMAIL=
ADMIN_PASSWORD=
ORGANIZATION_INVITATION_EXPIRY_DAYS=14

FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_AUTOMATION_DRY_RUN=true
FACEBOOK_AUTOMATION_CRON_TOKEN=
